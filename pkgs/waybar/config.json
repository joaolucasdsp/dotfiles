{
    "layer": "top",
    "position": "top",
    "margin-top": 2,
    "margin-left": 10,
    "margin-right": 10,
    "height": 20,
    "spacing": 0,
    "modules-left": [
        "custom/launcher",
        "sway/workspaces"
